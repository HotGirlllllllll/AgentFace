# AgentFace Configuration

# Database
DATABASE_URL=sqlite:///./data/agent_face.db
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_face  # Production

# Model Services
MULTIMODAL_MODEL_URL=http://localhost:8001
BEAUTIFY_MODEL_URL=http://localhost:8002
MODEL_REQUEST_TIMEOUT=60.0

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Image Constraints
MAX_IMAGE_DIMENSION=4096
MAX_IMAGE_BYTES=10485760
ALLOWED_IMAGE_FORMATS=image/jpeg,image/png,image/webp

# Memory
PREFERENCE_LEARNING_RATE=0.4
MIN_SESSIONS_FOR_AUTOMATION=1

# Safety
ENABLE_CONTENT_SAFETY=true
ENABLE_PII_DETECTION=false
OVER_SMOOTHING_THRESHOLD=0.15

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
ENABLE_TRACING=false
